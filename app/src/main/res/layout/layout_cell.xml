<?xml version="1.0" encoding="utf-8"?>
<CellLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:z="http://schemas.android.com/apk/res-auto"
    z:layout_cells="2,8" z:layout_space="10dp"
    android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:gravity="start" z:pad="1dp">
    <ListView
        android:id="@+id/list1"
        android:layout_x="0px" android:layout_y="0px" android:layout_width="2px" android:layout_height="3px"
        z:background="%drawable/bitmap_common" z:pad="10dp" z:bkTiles="@integer/selectDrop" z:selColor="#ff00ffff" />
    <EditText
        android:id="@+id/edit1" z:inputMode="text"
        android:layout_x="0px" android:layout_y="3px" android:layout_width="2px" android:layout_height="1px"
        z:textColor="%color/color_text_text" z:textSize="30sp" z:hint="@string/app_name"
        z:pad="10dp" android:gravity="center_vertical" z:foreground="%drawable/bitmap_common" z:fkTiles="@integer/edit"
        z:font="%drawable/font1" z:textWrap="true" />
    <Button
        android:id="@+id/button1"
        android:layout_x="0px" android:layout_y="4px" android:layout_width="2px" android:layout_height="1px"
        z:fkTiles="@integer/gradientRadial" z:foreground="@drawable/zssh" z:fkGravity="center" z:iconka="@integer/iconCancel"
        z:font="%drawable/font1" android:gravity="center" z:fkScale="1.0"
        android:text="@string/themeDark" z:textColor="%color/color_text_text" z:textSize="40sp"
        z:pad="5dp" z:tap="hovered" />
    <Switch
        android:id="@+id/switch1"
        android:layout_x="0px" android:layout_y="5px" android:layout_width="2px" android:layout_height="1px"
        android:text="Переключатель" z:textSize="40sp" z:textColor="%color/color_text_text"
        z:foreground="%drawable/bitmap_common" z:fkTile1="@integer/switchTrumb" z:fkTile2="@integer/switchTrack"
        z:pad="5dp" android:gravity="start|center_vertical" z:fkGravity="end" z:duration="10"
        z:font="%drawable/font2" z:fkScale="1.75" />
    <SeekBar
        android:id="@+id/seek"
        android:layout_x="0px" android:layout_y="6px" android:layout_width="2px" android:layout_height="1px"
        z:foreground="%drawable/bitmap_common" z:textSize="40sp" z:textColor="%color/color_slider_text"
        z:fkTiles="@integer/sliderTrumb1" z:fkTile2="@integer/sliderTrack1" android:gravity="center" z:fkScale="1.0"
        z:sliderMode="%integer/slider_mode" z:bkTiles="@integer/header" z:background="%drawable/bitmap_common"
        z:duration="40" z:font="%drawable/font2" android:orientation="horizontal"
        z:pad="1dp" z:range="0,70" />
    <ProgressBar
        android:id="@+id/progress1"
        android:layout_x="0px" android:layout_y="7px" android:layout_width="2px" android:layout_height="1px"
        z:foreground="@drawable/zssh" z:fkTile1="@integer/progressWait" z:fkTile2="@integer/rectRound" z:fkTile3="@integer/rectRound"
        z:fkColor="#ffffff" z:primary="%color/color_progress_primary"
        z:pad="5dp" android:orientation="horizontal" z:font="%drawable/font2"
        z:textColor="%color/color_progress_text" z:textSize="20sp" android:gravity="center" z:textShadowOffset="0,0"
        z:padStart="1dp" z:padTop="2dp" z:padEnd="3dp" z:padBottom="4dp"
        z:range="0,70" z:pos="50" z:sliderMode="rotate" z:display="visibled|tips" z:fkScale="2.5" />
</CellLayout>
